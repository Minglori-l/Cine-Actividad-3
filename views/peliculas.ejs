<!DOCTYPE html>
<html>
<head>
    <title>Cartelera de Películas</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <style>
        /* Fondo con degradado temático de cielo */
        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background: linear-gradient(180deg, #d4ecfc 0%, #eff6ff 45%, #f9fbfd 100%);
            background-attachment: fixed;
            margin: 0;
            padding: 40px 20px;
            color: #2c3e50;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        /* 👑 Barra de usuario superior */
        .user-bar {
            max-width: 1000px;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #1e3d59;
            color: white;
            padding: 12px 25px;
            border-radius: 12px;
            margin-bottom: 20px;
            box-shadow: 0 4px 15px rgba(30, 61, 89, 0.15);
            box-sizing: border-box;
        }

        .btn-logout {
            background-color: #e74c3c;
            color: white;
            text-decoration: none;
            padding: 6px 14px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.85rem;
            transition: background 0.2s;
        }

        .btn-logout:hover {
            background-color: #c0392b;
        }

        /* Contenedor tipo tarjeta limpia para la tabla */
        .content-container {
            max-width: 1000px;
            width: 100%;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 8px 32px rgba(31, 61, 89, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-sizing: border-box;
            margin-bottom: 30px;
        }

        /* Título de la sección */
        h1, h2 {
            color: #1e3d59;
            margin-top: 0;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        h1 { font-size: 2.2rem; margin-bottom: 10px; }
        h2 { font-size: 1.6rem; margin-bottom: 15px; border-bottom: 2px dashed #b4dbf7; padding-bottom: 8px; }

        p {
            color: #5a6b7c;
            font-size: 1.05rem;
            margin-top: 0;
            margin-bottom: 25px;
        }

        /* Botón azul estilizado para nueva película */
        .btn-create {
            display: inline-block;
            background-color: #3498db;
            color: white;
            padding: 12px 20px;
            text-decoration: none;
            font-weight: 600;
            border-radius: 8px;
            margin-bottom: 30px;
            transition: all 0.2s ease;
            box-shadow: 0 4px 12px rgba(52, 152, 219, 0.2);
        }

        .btn-create:hover {
            background-color: #2980b9;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(52, 152, 219, 0.3);
        }

        /* Estilización para la Tabla de Datos */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25px;
            background: #ffffff;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.02);
        }

        th {
            background-color: #1e3d59;
            color: #ffffff;
            font-weight: 600;
            text-align: left;
            padding: 14px 16px;
            font-size: 0.95rem;
        }

        td {
            padding: 14px 16px;
            border-bottom: 1px solid #eef2f5;
            color: #4a5568;
            font-size: 0.95rem;
        }

        tr:last-child td { border-bottom: none; }
        tr:hover td { background-color: #f8fafd; }

        .link-action {
            color: #3498db;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
            margin-right: 12px;
        }

        .link-action:hover {
            color: #1f6fa2;
            text-decoration: underline;
        }

        .link-edit {
            color: #f39c12;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
            margin-right: 12px;
        }

        .link-edit:hover {
            color: #d35400;
            text-decoration: underline;
        }

        .btn-delete {
            color: #e74c3c;
            cursor: pointer;
            border: none;
            background: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: color 0.2s;
            padding: 0;
        }

        .btn-delete:hover {
            color: #c0392b;
            text-decoration: underline;
        }

        .link-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #718096;
            text-decoration: none;
            font-weight: 500;
            margin-top: 15px;
            transition: color 0.2s;
        }

        .link-back:hover { color: #1e3d59; }

        .api-render-container {
            background: #fdfefe;
            border-left: 5px solid #3498db;
            padding: 15px 20px;
            border-radius: 4px 10px 10px 4px;
            margin-top: 10px;
        }
        
        .api-item {
            padding: 8px 0;
            border-bottom: 1px dashed #e2e8f0;
            display: flex;
            justify-content: space-between;
            font-size: 0.92rem;
        }
        
        .api-item:last-child { border-bottom: none; }
        .badge-api { background: #3498db; color: white; padding: 2px 6px; border-radius: 4px; font-size: 0.75rem; font-weight: bold; }
    </style>
</head>
<body>

    <!-- 🛠️ HELPER LOCAL PARA VERIFICAR ROLES (Insensible a mayúsculas/minúsculas) -->
    <% 
        const esAdminOEmpleado = user && user.rol && ['administrador', 'admin', 'empleado'].includes(String(user.rol).toLowerCase());
        const nombreUsuario = user ? (user.username || user.nombre || 'Usuario') : '';
    %>

    <!-- 👤 BARRA DE USUARIO LOGUEADO -->
    <% if (user) { %>
        <div class="user-bar">
            <span>👤 Conectado como: <strong><%= nombreUsuario %></strong> (<span style="color:#f1c40f;"><%= user.rol %></span>)</span>
            <a href="/users/logout" class="btn-logout">🔑 Cerrar Sesión</a>
        </div>
    <% } %>

    <div class="content-container">
        <h1>🎬 Cartelera de Películas (Renderizado por Vista/EJS)</h1>
        <p>Gestión de los títulos disponibles en el complejo de cine.</p>
        
        <!-- 🔐 BOTÓN CREAR: Visible para Administrador y Empleado -->
        <% if (esAdminOEmpleado) { %>
            <a href="/nueva-pelicula" class="btn-create">+ Añadir Nueva Película</a>
        <% } %>

        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Título</th>
                    <th>Director</th>
                    <th>Año</th>
                    <!-- 🔐 Cabecera de acciones: Visible si hay sesión activa -->
                    <% if (user) { %>
                        <th><%= esAdminOEmpleado ? 'Acciones' : 'Información' %></th>
                    <% } %>
                </tr>
            </thead>
            <tbody>
                <% peliculas.forEach(function(pelicula) { %>
                    <tr>
                        <td><%= pelicula.id %></td>
                        <td><strong><%= pelicula.titulo %></strong></td>
                        <td><%= pelicula.director %></td>
                        <td><%= pelicula.anio %></td>

                        <!-- 🔐 Columna de opciones -->
                        <% if (user) { %>
                            <td>
                                <a href="/pelicula/<%= pelicula.id %>" class="link-action">🔍 Ver Detalles</a>
                                
                                <% if (esAdminOEmpleado) { %>
                                    <a href="/pelicula/editar/<%= pelicula.id %>" class="link-edit">✏️ Editar</a>
                                    <button onclick="eliminarPelicula(<%= pelicula.id %>)" class="btn-delete">🗑️ Eliminar</button>
                                <% } %>
                            </td>
                        <% } %>
                    </tr>
                <% }); %>
            </tbody>
        </table>

        <a href="/" class="link-back">🏠 Volver al inicio</a>
    </div>

    <!-- 🔐 FEED DE CARTELERA ASÍNCRONA -->
    <% if (user) { %>
        <div class="content-container">
            <h2>⚡ Feed de Cartelera Asíncrona <span class="badge-api">CLIENT-SIDE FETCH</span></h2>
            <p style="color:#718096; font-size:0.9rem; margin-top:0;">Esta sección se genera de forma reactiva pidiendo los objetos directamente a tu endpoint del API JSON:</p>
            
            <div class="api-render-container">
                <div id="lista-peliculas-api">
                    <p style="color:#a0aec0; font-style:italic;">Cargando catálogo dinámico...</p>
                </div>
            </div>
        </div>
    <% } %>

    <script>
    function eliminarPelicula(id) {
        if (confirm('¿Seguro que quieres borrar esta película?')) {
            fetch('/pelicula/eliminar/' + id, {
                method: 'DELETE'
            })
            .then(respuesta => respuesta.json())
            .then(datos => {
                window.location.reload(); 
            })
            .catch(error => console.log('Error:', error));
        }
    }

    document.addEventListener("DOMContentLoaded", function() {
        const contenedorApi = document.getElementById('lista-peliculas-api');
        
        if (contenedorApi) {
            fetch('/api/peliculas') 
                .then(response => {
                    if (!response.ok) {
                        throw new Error('No autorizado');
                    }
                    return response.json();
                })
                .then(data => {
                    contenedorApi.innerHTML = '';
                    
                    if(data.length === 0) {
                        contenedorApi.innerHTML = `<p style="color:#a0aec0;">No hay títulos indexados en el log de la API.</p>`;
                        return;
                    }

                    data.forEach(p => {
                        const div = document.createElement('div');
                        div.className = 'api-item';
                        div.innerHTML = `
                            <span>🎥 <strong>${p.titulo}</strong> (Dir: ${p.director})</span>
                            <span style="color:#2980b9;">📅 Estreno: <strong>${p.anio}</strong></span>
                        `;
                        contenedorApi.appendChild(div);
                    });
                })
                .catch(error => {
                    console.error('Error en fetch de la API de películas:', error);
                    contenedorApi.innerHTML = `
                        <p style="color:#e67e22;">⚠️ <strong>Acceso limitado:</strong> Solo los administradores y empleados pueden sincronizar directamente con el feed del API JSON.</p>
                    `;
                });
        }
    });
    </script>
</body>
</html>