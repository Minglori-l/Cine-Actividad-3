<!DOCTYPE html>
<html>
<head>
    <title>Añadir Nueva Película</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <style>
        /* 🌤️ Fondo celeste claro unificado */
        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #eef6ff; 
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            box-sizing: border-box;
        }

        /* ⬜ Tarjeta blanca impecable */
        .card {
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(30, 61, 89, 0.04);
            padding: 40px;
            width: 100%;
            max-width: 480px;
            box-sizing: border-box;
        }

        /* 🎥 Título de la sección */
        .card-title {
            color: #1e3d59;
            font-size: 1.75rem;
            font-weight: 700;
            margin-top: 0;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* 📝 Subtítulo/Descripción del formulario */
        .card-subtitle {
            color: #718096;
            font-size: 0.95rem;
            margin-top: 0;
            margin-bottom: 20px;
            line-height: 1.4;
        }

        /* ✂️ Línea divisoria punteada azul clara */
        .divider {
            border: none;
            border-bottom: 1px dashed #b4dbf7;
            margin-bottom: 30px;
        }

        /* Bloques de los campos */
        .form-group {
            margin-bottom: 22px;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            color: #4a5568;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        /* 📝 Inputs limpios con bordes redondeados */
        .form-control {
            width: 100%;
            padding: 12px 16px;
            font-size: 0.95rem;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            color: #334155;
            background-color: #ffffff;
            box-sizing: border-box;
            transition: all 0.2s ease;
            outline: none;
        }

        .form-control:focus {
            border-color: #abc9e9;
            box-shadow: 0 0 0 3px rgba(171, 201, 233, 0.2);
        }

        /* 🔘 Contenedor de acciones */
        .actions {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-top: 32px;
        }

        /* 🟢 Botón verde vibrante para guardar */
        .btn-submit {
            background-color: #22c55e; 
            color: white;
            border: none;
            border-radius: 8px;
            padding: 12px 22px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 12px rgba(34, 197, 94, 0.15);
            transition: all 0.2s ease;
        }

        .btn-submit:hover {
            background-color: #16a34a;
        }

        /* Enlace cancelar */
        .btn-cancel {
            color: #718096;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: color 0.2s;
        }

        .btn-cancel:hover {
            color: #4a5568;
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div class="card">
        <!-- Título con icono de cámara de cine -->
        <h1 class="card-title">🎥 Añadir Nueva Película</h1>
        <p class="card-subtitle">Completa la información para registrar el filme en la base de datos.</p>
        <div class="divider"></div>

        <!-- 🌟 Formulario corregido apuntando a la ruta RESTful correcta -->
        <form action="/api/peliculas" method="POST">
            
            <!-- 1. Título del Filme -->
            <div class="form-group">
                <label for="titulo">Título del Filme:</label>
                <input type="text" 
                       name="titulo" 
                       id="titulo" 
                       class="form-control" 
                       placeholder="Ej. Inception" 
                       required autocomplete="off">
            </div>

            <!-- 2. Director -->
            <div class="form-group">
                <label for="director">Director:</label>
                <input type="text" 
                       name="director" 
                       id="director" 
                       class="form-control" 
                       placeholder="Ej. Christopher Nolan" 
                       required autocomplete="off">
            </div>

            <!-- 3. Año de Estreno -->
            <div class="form-group">
                <label for="anio">Año de Estreno:</label>
                <input type="number" 
                       name="anio" 
                       id="anio" 
                       class="form-control" 
                       placeholder="Ej. 2010" 
                       required>
            </div>

            <!-- Botones de Acción -->
            <div class="actions">
                <button type="submit" class="btn-submit">
                    <span>💾</span> Guardar Película
                </button>
                <a href="/api/peliculas/cartelera" class="btn btn-secondary">Cancelar</a>
            </div>

        </form>
    </div>

</body>
</html>