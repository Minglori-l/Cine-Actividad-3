<!DOCTYPE html>
<html>
<head>
    <title>Nuevo Ticket</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
</head>
<body>
    <h1>Vender Nuevo Ticket</h1>
    
    <form action="/tickets/nuevo" method="POST">
        <div style="margin-bottom: 15px;">
            <label>Seleccionar Función:</label><br>
            <select name="funcion_id" required style="padding: 8px; width: 318px;">
                <% funciones.forEach(function(funcion) { %>
                    <option value="<%= funcion.id %>"><%= new Date(funcion.fecha).toLocaleString() %> - <%= funcion.sala_nombre %></option>
                <% }); %>
            </select>
        </div>
        <div style="margin-bottom: 15px;">
            <label>Asiento (Ej. A1, B4):</label><br>
            <input type="text" name="asiento" required style="padding: 8px; width: 300px;">
        </div>
        <div style="margin-bottom: 15px;">
            <label>Precio ($):</label><br>
            <input type="number" step="0.01" name="precio" required style="padding: 8px; width: 300px;">
        </div>
        <button type="submit" style="padding: 10px 20px; background: #28a745; color: white; border: none; border-radius: 5px; cursor: pointer;">Vender Ticket</button>
        <a href="/tickets" style="margin-left: 10px; text-decoration: none; color: gray;">Cancelar</a>
    </form>
</body>
</html>