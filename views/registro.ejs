<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registro - Cine Caproni</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>

        /* Configuración con vibras Ghibli / Cine Clásico */
    body {
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
       /* FONDO: Imagen */
        background-image: url('https://i.pinimg.com/1200x/fb/db/0a/fbdb0a9ee462ea649b2c5133e8b5acc6.jpg');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        
        /* ✍️ COLOR DE TEXTO GENERAL */
        color: #ffffff; 

        margin: 0;
        padding: 40px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
    }
        .card {
            background-color: #337edfbe;
            border: 1px solid #043a77d0;
            border-radius: 10px;
        }
        .btn-success {
            background-color: #2320c0;
            border: none;
        }
        .btn-success:hover {
            background-color: #392fc0;
        }
        a {
            color: #2a09e5;
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card p-4 shadow-lg">
                <h2 class="text-center mb-4">🎥 Cine Caproni</h2>
                <h5 class="text-center text-muted mb-4">Crear Nueva Cuenta</h5>

                <!-- Mostrar alertas de error o éxito -->
                <% if (error) { %>
                    <div class="alert alert-danger" role="alert">
                        <%= error %>
                    </div>
                <% } %>
                <% if (success) { %>
                    <div class="alert alert-success" role="alert">
                        <%= success %>
                    </div>
                <% } %>

                <form action="/users/registro" method="POST">
                    <div class="mb-3">
                        <label for="username" class="form-label">Nombre de Usuario</label>
                        <input type="text" class="form-control bg-dark text-white border-secondary" id="username" name="username" required placeholder="Ej: maria_cine">
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">Contraseña</label>
                        <input type="password" class="form-control bg-dark text-white border-secondary" id="password" name="password" required placeholder="Mínimo 6 caracteres">
                    </div>
                    <div class="mb-3">
                        <label for="rol" class="form-label">Rol del Usuario</label>
                        <select class="form-select bg-dark text-white border-secondary" id="rol" name="rol" required>
                            <option value="Cliente" selected>Cliente (Público)</option>
                            <option value="Empleado">Empleado (Gestor de Salas)</option>
                            <option value="Administrador">Administrador (Control Total)</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-success w-100 py-2 mt-3">Registrarse</button>
                </form>

                <p class="text-center mt-4 mb-0 text-muted">
                    ¿Ya tienes cuenta? <a href="/users/login">Inicia sesión aquí</a>
                </p>
            </div>
        </div>
    </div>
</div>

</body>
</html>