<!DOCTYPE html>
<html>
<head>
    <title>Editar Película</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <style>
        /* 🌤️ Fondo celeste claro unificado */
        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #eef6ff; 
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            box-sizing: border-box;
        }

        /* ⬜ Tarjeta blanca idéntica a las anteriores */
        .card {
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(30, 61, 89, 0.04);
            padding: 40px;
            width: 100%;
            max-width: 480px;
            box-sizing: border-box;
        }

        /* 🎬 Título de la sección */
        .card-title {
            color: #1e3d59;
            font-size: 1.75rem;
            font-weight: 700;
            margin-top: 0;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        /* ✂️ Línea divisoria punteada azul clara */
        .divider {
            border: none;
            border-bottom: 1px dashed #b4dbf7;
            margin-bottom: 30px;
        }

        /* Bloques de los campos */
        .form-group {
            margin-bottom: 22px;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            color: #4a5568;
            margin-bottom: 8px;
            font-size: 0.95rem;
        }

        /* 📝 Inputs pulidos y limpios */
        .form-control {
            width: 100%;
            padding: 12px 16px;
            font-size: 0.95rem;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            color: #334155;
            background-color: #ffffff;
            box-sizing: border-box;
            transition: all 0.2s ease;
            outline: none;
        }

        .form-control:focus {
            border-color: #abc9e9;
            box-shadow: 0 0 0 3px rgba(171, 201, 233, 0.2);
        }

        /* 🔘 Contenedor de acciones */
        .actions {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-top: 32px;
        }

        /* 🔵 Botón azul profesional para Actualizar */
        .btn-submit {
            background-color: #3498db; 
            color: white;
            border: none;
            border-radius: 8px;
            padding: 12px 22px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 12px rgba(52, 152, 219, 0.15);
            transition: all 0.2s ease;
        }

        .btn-submit:hover {
            background-color: #2980b9;
        }

        /* Enlace cancelar */
        .btn-cancel {
            color: #718096;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: color 0.2s;
        }

        .btn-cancel:hover {
            color: #4a5568;
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div class="card">
        <h1 class="card-title">🎬 Editar Película</h1>
        <div class="divider"></div>

        <!-- Ajusta el action según manejes tus rutas de películas -->
        <form action="/api/peliculas/editar/<%= pelicula.id %>" method="POST">
            
            <!-- 1. Título de la película -->
            <div class="form-group">
                <label for="titulo">Título:</label>
                <input type="text" 
                       name="titulo" 
                       id="titulo" 
                       class="form-control" 
                       value="<%= pelicula.titulo %>" 
                       placeholder="Ej. Inception" 
                       required autocomplete="off">
            </div>

            <!-- 2. Director -->
            <div class="form-group">
                <label for="director">Director:</label>
                <input type="text" 
                       name="director" 
                       id="director" 
                       class="form-control" 
                       value="<%= pelicula.director %>" 
                       placeholder="Ej. Christopher Nolan" 
                       required autocomplete="off">
            </div>

            <!-- 3. Año de estreno -->
            <div class="form-group">
                <label for="anio">Año:</label>
                <input type="number" 
                       name="anio" 
                       id="anio" 
                       class="form-control" 
                       value="<%= pelicula.anio %>" 
                       placeholder="Ej. 2010" 
                       required>
            </div>

            <!-- Botones de Acción -->
            <div class="actions">
                <button type="submit" class="btn-submit">
                    <span>💾</span> Actualizar Película
                </button>
               <a href="/api/peliculas/cartelera" class="btn-cancel">Cancelar</a>
            </div>

        </form>
    </div>

</body>
</html>