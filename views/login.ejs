<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iniciar Sesión - Cine Caproni</title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* Configuración con vibras Ghibli / Cine Clásico */
        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-image: url('https://images.squarespace-cdn.com/content/v1/60c0cbb7ba596c14b0e1d74b/43f2bad3-5cb3-4985-adfd-42097786cd9c/Totoro-main-2.gif');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            margin: 0;
            padding: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            color: #ffffff;
        }

        .card {
            background-color: rgba(32, 136, 196, 0.88);
            border: 1px solid rgba(18, 123, 155, 0.64);
            border-radius: 12px;
            backdrop-filter: blur(4px); /* Suaviza el fondo detrás de la tarjeta */
        }

        .btn-primary {
            background-color: #2a09e5;
            border: none;
        }

        .btn-primary:hover {
            background-color: #0a1fdae0;
        }

        a {
            color: #ffffff;
            font-weight: bold;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card p-4 shadow-lg">
                <h2 class="text-center mb-1 text-white">Cine Caproni</h2>
                <h5 class="text-center text-light opacity-75 mb-4">Iniciar Sesión</h5>

                <!-- 🚨 ALERTA DE RESTRICCIÓN / EXPIRACIÓN -->
                <% if (locals.mensaje === 'requerido') { %>
                    <div class="alert alert-warning text-center small shadow-sm" role="alert">
                        🔒 <strong>¡Acceso restringido!</strong> Inicia sesión o regístrate para acceder a esta sección.
                    </div>
                <% } else if (locals.mensaje === 'expirado') { %>
                    <div class="alert alert-info text-center small shadow-sm" role="alert">
                        ⏰ Tu sesión ha caducado. Por favor, ingresa nuevamente.
                    </div>
                <% } %>

                <!-- ❌ MOSTRAR ERROR DE CONTRASEÑA/USUARIO -->
                <% if (error) { %>
                    <div class="alert alert-danger text-center small" role="alert">
                        <%= error %>
                    </div>
                <% } %>

                <form action="/users/login" method="POST">
                    <div class="mb-3">
                        <label for="username" class="form-label text-white fw-medium">Usuario</label>
                        <input type="text" class="form-control bg-dark text-white border-secondary" id="username" name="username" required placeholder="Ej: admin">
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label text-white fw-medium">Contraseña</label>
                        <input type="password" class="form-control bg-dark text-white border-secondary" id="password" name="password" required placeholder="••••••••">
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2 mt-3 shadow-sm">Ingresar</button>
                </form>

                <p class="text-center mt-4 mb-0 text-light small">
                    ¿No tienes cuenta? <a href="/users/registro">Regístrate aquí</a>
                </p>
            </div>
        </div>
    </div>
</div>

</body>
</html>