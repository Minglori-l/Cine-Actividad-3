<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= titulo %></title>
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #e0f2fe 0%, #f0f9ff 100%);
            min-height: 100vh;
            color: #1e293b;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .card {
            background-color: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            color: #1e293b;
        }
        .text-ghibli {
            color: #1f3a52;
        }
        .table-ghibli-header th {
            background-color: #1f3a52 !important;
            color: #ffffff !important;
        }
        .btn-cinema {
            background-color: #1f3a52;
            color: white;
            border: none;
            transition: background-color 0.2s ease;
        }
        .btn-cinema:hover {
            background-color: #152839;
            color: white;
        }
        .form-control, .form-select {
            border-color: #cbd5e1;
        }
        .form-control:focus, .form-select:focus {
            border-color: #1f3a52;
            box-shadow: 0 0 0 0.25rem rgba(31, 58, 82, 0.15);
        }
    </style>
</head>
<body class="p-4">
    <div class="container">
        <!-- Encabezado -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 text-ghibli fw-bold mb-0"><%= titulo %></h1>
                <% if (usuario) { %>
                    <small class="text-muted">Sesión iniciada como: <span class="badge bg-info text-dark fw-bold"><%= usuario.rol %></span></small>
                <% } %>
            </div>
            <a href="/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">← Volver al Inicio</a>
        </div>

        <!-- Formulario para agregar producto (Oculto para Clientes) -->
        <% if (usuario && (usuario.rol === 'Administrador' || usuario.rol === 'Empleado')) { %>
            <div class="card p-4 mb-4 shadow-sm">
                <h2 class="h5 mb-3 text-ghibli fw-bold">🍿 Agregar Nuevo Producto</h2>
                <form action="/api/dulces" method="POST">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label text-secondary fw-semibold small">Nombre</label>
                            <input type="text" name="nombre" class="form-control" placeholder="Ej. Palomitas Grandes" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-secondary fw-semibold small">Categoría</label>
                            <select name="categoria" class="form-select" required>
                                <option value="" disabled selected>Selecciona...</option>
                                <option value="Palomitas">Palomitas</option>
                                <option value="Bebidas">Bebidas</option>
                                <option value="Golosinas">Golosinas</option>
                                <option value="Combos">Combos</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-secondary fw-semibold small">Precio ($)</label>
                            <input type="number" step="0.01" name="precio" class="form-control" placeholder="0.00" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label text-secondary fw-semibold small">Stock Inicial</label>
                            <input type="number" name="stock" class="form-control" placeholder="0" value="0">
                        </div>
                    </div>
                    <div class="mt-3 text-end">
                        <button type="submit" class="btn btn-cinema fw-bold rounded-pill px-4">Guardar Producto</button>
                    </div>
                </form>
            </div>
        <% } %>

        <!-- Tabla de catálogo -->
        <div class="card p-4 shadow-sm">
            <h2 class="h5 mb-3 text-ghibli fw-bold">🥤Dulces Disponibles🍿</h2>
            <div class="table-responsive rounded-3 border">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr class="table-ghibli-header">
                            <th>ID</th>
                            <th>Producto</th>
                            <th>Categoría</th>
                            <th>Precio</th>
                            <th>Stock</th>
                            <!-- Columna Acciones solo visible para Administrador/Empleado -->
                            <% if (usuario && usuario.rol !== 'Cliente') { %>
                                <th class="text-center">Acciones</th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (dulces && dulces.length > 0) { %>
                            <% dulces.forEach(dulce => { %>
                                <tr>
                                    <td class="text-muted">#<%= dulce.id %></td>
                                    <td class="fw-bold text-dark"><%= dulce.nombre %></td>
                                    <td><span class="badge bg-light text-dark border"><%= dulce.categoria %></span></td>
                                    <td class="fw-semibold">$<%= parseFloat(dulce.precio).toFixed(2) %></td>
                                    <td>
                                        <span class="badge <%= dulce.stock > 10 ? 'bg-success' : 'bg-danger' %>">
                                            <%= dulce.stock %> unids.
                                        </span>
                                    </td>
                                    <!-- Botones según jerarquía del Rol -->
                                    <% if (usuario && usuario.rol !== 'Cliente') { %>
                                        <td class="text-center">
                                            <% if (usuario.rol === 'Administrador') { %>
                                                <button data-id="<%= dulce.id %>" onclick="eliminarDulce(this.dataset.id)" class="btn btn-outline-danger btn-sm rounded-3">Eliminar</button>
                                            <% } else { %>
                                                <span class="text-muted small">Sin permisos para borrar</span>
                                            <% } %>
                                        </td>
                                    <% } %>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="<%= (usuario && usuario.rol !== 'Cliente') ? '6' : '5' %>" class="text-center text-muted py-4">
                                    No hay productos registrados en dulcería.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        async function eliminarDulce(id) {
            if (confirm('¿Deseas eliminar este producto de la dulcería?')) {
                try {
                    const res = await fetch(`/api/dulces/${id}`, { method: 'DELETE' });
                    if (res.ok) {
                        window.location.reload();
                    } else {
                        alert('Error al eliminar el producto');
                    }
                } catch (err) {
                    console.error(err);
                    alert('Error de conexión');
                }
            }
        }
    </script>
</body>
</html>