<!DOCTYPE html>
<html>
<head>
    <title>Editar Ticket</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
</head>
<body>
    <h1>Editar Ticket #<%= ticket.id %></h1>
    
    <form action="/tickets/editar/<%= ticket.id %>" method="POST">
        <div style="margin-bottom: 15px;">
            <label>Seleccionar Función:</label><br>
            <select name="funcion_id" required style="padding: 8px; width: 318px;">
                <% funciones.forEach(function(funcion) { %>
                    <option value="<%= funcion.id %>" <%= ticket.funcion_id === funcion.id ? 'selected' : '' %>>
                        <%= new Date(funcion.fecha).toLocaleString() %> - <%= funcion.sala_nombre %>
                    </option>
                <% }); %>
            </select>
        </div>
        <div style="margin-bottom: 15px;">
            <label>Asiento:</label><br>
            <input type="text" name="asiento" value="<%= ticket.asiento %>" required style="padding: 8px; width: 300px;">
        </div>
        <div style="margin-bottom: 15px;">
            <label>Precio ($):</label><br>
            <input type="number" step="0.01" name="precio" value="<%= ticket.precio %>" required style="padding: 8px; width: 300px;">
        </div>
        <button type="submit" style="padding: 10px 20px; background: #007bff; color: white; border: none; border-radius: 5px; cursor: pointer;">Actualizar Ticket</button>
        <a href="/tickets" style="margin-left: 10px; text-decoration: none; color: gray;">Cancelar</a>
    </form>
</body>
</html>